# Copy this file into an individual app folder as .env when you want
# production controls for that app.

APP_ENV=production
HOST=127.0.0.1
PORT=5174
ALLOWED_HOSTS=127.0.0.1,localhost,ledger.local

# Required in production. Use a long unique password per deployment.
APP_BASIC_AUTH_USERNAME=admin
APP_BASIC_AUTH_PASSWORD=change-this-to-a-long-random-password

# Request body limit for JSON/static apps.
MAX_BODY_MB=25

# Utility apps can override these.
# MAX_UPLOAD_MB=500
# OUTPUT_ROOT=/home/ztothez/Documents/obsidian/local-vault/Converted
# VIDEOS_ROOT=/home/ztothez/Videos
# MARKITDOWN=/home/ztothez/.local/bin/markitdown
# YT_DLP=/home/ztothez/.local/bin/yt-dlp

# AI Roadmap route proxy.
# CURSOR_API_KEY=
# CURSOR_MODEL=claude-4-sonnet
